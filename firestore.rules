rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── EXISTING: live tournament publish (sync from running app) ───────────
    match /tournaments/{tid} {
      // Anyone can read a published tournament (view-only QR users).
      allow read: if true;

      // Anyone signed in (anonymous auth ok) can create a tournament,
      // but the document MUST claim them as the owner.
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.state is map;

      // Only the owner can update or delete their tournament.
      // The ownerUid field cannot be changed.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid
                    && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;

      // Self-report match reports — append-only audit log written by the
      // submitMatchReport callable (Admin SDK; rules bypassed). Public read
      // so viewers + owner both see pending / confirmed / disputed reports.
      // Direct client create is locked off — callable is the only path so
      // shape + reporter trainerId are validated server-side.
      match /matchReports/{rid} {
        allow read: if true;
        allow create: if false;
        allow update, delete: if request.auth != null
                              && request.auth.uid == get(/databases/$(database)/documents/tournaments/$(tid)).data.ownerUid;
      }
    }

    // ── NEW: hosted PTCG events (registration before tournament start) ──────
    // Public meta is readable by anyone (drives the participant signup page).
    // Sensitive fields (signups with phone / deck) live in `private/` sub-doc
    // so only the organizer can read them.
    match /events/{eid} {
      // Public meta read — title, date, prizes, etc. Includes editKeyHash,
      // which is a one-way hash and safe to expose. Phones/PII are NOT here.
      allow read: if true;

      // Create: signed-in (anonymous) caller claims ownership of a fresh doc.
      // editKeyHash must be a string (the actual key is shown to organizer
      // once and never stored in Firestore — only its hash for future P2
      // cross-device claim).
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.editKeyHash is string
                    && request.resource.data.eventId is string
                    && request.resource.data.phase is string;

      // Update: owner only. Three immutables (ownerUid / editKeyHash / eventId)
      // and a phase-aware field-freeze:
      //
      //   phase=signup   → full edit (current behaviour)
      //   phase=live     → only result-pipeline + status fields can change.
      //                    meta / prizes / desc / image / capacity / signupOpen
      //                    are FROZEN (organizer can't move goalposts mid-bracket).
      //   phase=ended    → same field set as `live`. Result snapshot + topcut
      //                    post-id may still update on rename / re-publish.
      //   phase=cancelled→ basically read-only; only phase can flip back to
      //                    `signup` (un-cancel).
      //
      // The mutable allowlist for non-signup phases:
      //   phase, tournamentResultSnapshot, tournamentId, topcutPostId,
      //   topcutResultPostId, published, syncToTopCut, signupCount,
      //   updatedAt, expiresAt, _resyncNonce
      function isSelfOwner() {
        return request.auth != null
               && request.auth.uid == resource.data.ownerUid;
      }
      function immutablesIntact() {
        // ownerUid is normally immutable on client writes; the cross-device
        // claimEvent Cloud Function uses Admin SDK to transfer it (rules
        // bypassed there). editKeyHash + eventId are absolute immutables.
        return request.resource.data.ownerUid == resource.data.ownerUid
               && request.resource.data.editKeyHash == resource.data.editKeyHash
               && request.resource.data.eventId == resource.data.eventId;
      }
      function postSignupAllowedKeys() {
        return ['phase', 'tournamentResultSnapshot', 'tournamentId',
                'topcutPostId', 'topcutResultPostId', 'published',
                'syncToTopCut', 'signupCount', 'updatedAt', 'expiresAt',
                '_resyncNonce'];
      }
      function fieldsLockedForPhase() {
        // Editing during signup is unrestricted; once live/ended/cancelled
        // the diff has to be a subset of the allowlist above.
        return resource.data.phase == 'signup'
               || request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(postSignupAllowedKeys());
      }

      allow update: if isSelfOwner()
                    && immutablesIntact()
                    && fieldsLockedForPhase();

      // Delete: only allowed while still in `signup` phase. Once a tournament
      // has been started (live), gone to standings (ended), or organisers
      // pulled the plug (cancelled), the event becomes part of the
      // historical record — admin tooling on TopCut handles takedowns.
      allow delete: if isSelfOwner()
                    && resource.data.phase == 'signup';

      // Signup sub-collection — contains player phone / trainer ID / deck.
      // Public can CREATE (anonymous signup) but cannot LIST or READ any
      // existing signup. Only the event owner can read / update / delete.
      match /signups/{sid} {
        // Owner-only read & list. Public cannot enumerate signups.
        allow read: if request.auth != null
                    && request.auth.uid == get(/databases/$(database)/documents/events/$(eid)).data.ownerUid;

        // Capacity gate — best-effort. Reads parent event's signupCount
        // (maintained by onSignupWritten trigger). A small race window
        // exists between the trigger firing and the next signup; for tight
        // caps the organizer should monitor the host page in real time.
        // capacity == null means unlimited. Organizer bypasses the cap so
        // they can still walk-in on-site players past the online limit.
        function withinCapacity() {
          let parent = get(/databases/$(database)/documents/events/$(eid)).data;
          let isOwner = request.auth != null && request.auth.uid == parent.ownerUid;
          return isOwner
                 || !('capacity' in parent)
                 || parent.capacity == null
                 || parent.signupCount < parent.capacity;
        }

        // Public create — anonymous participant fills out the signup form.
        // Required field shape enforced; size capped to prevent abuse.
        allow create: if request.auth != null
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.name.size() < 100
                      && request.resource.data.trainerId is string
                      && request.resource.data.phone is string
                      && request.resource.data.species1 is string
                      && request.resource.data.source in ['online', 'walkin']
                      && request.resource.data.checkedIn == false
                      && request.resource.data.paid == false
                      && withinCapacity();

        // Owner-only update (check-in, payment, edit) and delete.
        allow update, delete: if request.auth != null
                              && request.auth.uid == get(/databases/$(database)/documents/events/$(eid)).data.ownerUid;
      }
    }
  }
}
